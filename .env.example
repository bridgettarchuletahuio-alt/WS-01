WWEBJS_TEST_REMOTE_ID=XXXXXXXXXX@c.us
WWEBJS_TEST_CLIENT_ID=authenticated

# Visual UI auth/session
JWT_SECRET=replace_with_strong_random_string
DATABASE_URL=postgres://...

# Multi-client role
WWEBJS_CLIENT_IDS=visual-ui-a,visual-ui-b,visual-ui-c
WWEBJS_MAIN_CLIENT_ID=visual-ui-a

# RemoteAuth (recommended when no local volume)
REMOTE_AUTH_ENABLED=true
REMOTE_AUTH_STORE=postgres
# If using mongo instead of postgres:
# REMOTE_AUTH_STORE=mongo
# REMOTE_AUTH_MONGO_URI=mongodb+srv://...
REMOTE_AUTH_DB_NAME=wwebjs
REMOTE_AUTH_COLLECTION=wwebjs_remote_sessions
REMOTE_AUTH_BACKUP_INTERVAL_MS=300000
